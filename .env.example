# Sercha Core Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required Configuration (Application will NOT start without these)
# =============================================================================

# Database connection string
# Format: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://sercha:sercha_dev@localhost:5432/sercha?sslmode=disable

# JWT secret for authentication tokens (64 hex characters = 32 bytes)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Master encryption key for sensitive data (64 hex characters = 32 bytes)
# Generate with: openssl rand -hex 32
MASTER_KEY=

# Vespa search engine configuration
VESPA_CONFIG_URL=http://localhost:19071
VESPA_CONTAINER_URL=http://localhost:8080

# =============================================================================
# Application Configuration
# =============================================================================

# Port for HTTP server (default: 8080)
PORT=8080

# Base URL for OAuth callbacks and webhooks
BASE_URL=http://localhost:8080

# Run mode: "all" (API + worker), "api" (API only), "worker" (worker only)
RUN_MODE=all

# =============================================================================
# OAuth Provider Credentials (Optional - enables providers)
# =============================================================================
# Configure only the providers you want to enable
# Both CLIENT_ID and CLIENT_SECRET are required for each provider

# GitHub
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab
# Get from: https://gitlab.com/-/profile/applications
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Slack
# Get from: https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Notion
# Get from: https://www.notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Confluence
# Get from: https://developer.atlassian.com/console/myapps/
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=

# Jira
# Get from: https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Google (Drive & Docs)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Linear
# Get from: https://linear.app/settings/api
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Dropbox
# Get from: https://www.dropbox.com/developers/apps
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# =============================================================================
# AI Provider Credentials (Optional - enables AI features)
# =============================================================================
# Configure to enable semantic search and LLM features

# OpenAI (Embedding + LLM)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (LLM only)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama (Self-hosted, no API key needed)
# Just set the base URL to your Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Cohere (Embedding only)
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.ai

# Voyage AI (Embedding only)
# Get from: https://www.voyageai.com/
VOYAGE_API_KEY=
VOYAGE_BASE_URL=https://api.voyageai.com/v1

# =============================================================================
# Operational Limits (Optional guardrails)
# =============================================================================

# Sync interval boundaries (minutes)
SYNC_MIN_INTERVAL=5
SYNC_MAX_INTERVAL=1440

# Maximum concurrent sync workers
MAX_WORKERS=10

# Maximum results per page in search
MAX_RESULTS_PER_PAGE=100

# =============================================================================
# Optional Infrastructure
# =============================================================================

# Redis (Optional - for caching and distributed task queue)
# If not set, PostgreSQL is used as fallback
REDIS_URL=redis://localhost:6379

# =============================================================================
# Database Connection Pool (Optional tuning)
# =============================================================================

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_SEC=300
DB_CONN_MAX_IDLE_SEC=60

# =============================================================================
# Worker Configuration (Optional)
# =============================================================================

# Worker concurrency (number of tasks processed in parallel)
WORKER_CONCURRENCY=2

# Worker dequeue timeout (seconds)
WORKER_DEQUEUE_TIMEOUT=5

# =============================================================================
# Scheduler Configuration (Optional)
# =============================================================================

# Enable/disable automatic scheduled syncs
SCHEDULER_ENABLED=true

# Require distributed lock for scheduler (set false for single-instance deployments)
SCHEDULER_LOCK_REQUIRED=true

# =============================================================================
# Development/Testing (Optional)
# =============================================================================

# LocalFS connector allowed roots (comma-separated paths)
# Only needed for local filesystem testing
LOCALFS_ALLOWED_ROOTS=/data,/tmp
