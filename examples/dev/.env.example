# Sercha Development Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required secrets (generate with: openssl rand -hex 32)
JWT_SECRET=
MASTER_KEY=

# GitHub OAuth (optional - for GitHub connector)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Notion OAuth (optional - for Notion connector)
# Create integration at: https://www.notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Microsoft OAuth (optional - for OneDrive connector)
# Create app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# OpenAI API Key (optional - for AI features)
OPENAI_API_KEY=

# OpenAI rate-limiter tuning (optional — defaults shown)
# OPENAI_TPM_LIMIT=200000          # tokens-per-minute budget (initial; updated from response headers)
# OPENAI_MAX_RETRIES=5             # max retry attempts on 429 / transient 5xx
# OPENAI_MAX_RETRY_ELAPSED_SEC=60  # max total seconds to spend retrying a single request
