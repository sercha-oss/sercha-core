# Sercha Development Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required secrets (generate with: openssl rand -hex 32)
JWT_SECRET=
MASTER_KEY=

# GitHub OAuth (optional - for GitHub connector)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Notion OAuth (optional - for Notion connector)
# Create integration at: https://www.notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Microsoft OAuth (optional - for OneDrive connector)
# Create app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# OpenAI API Key (optional - for AI features)
OPENAI_API_KEY=
